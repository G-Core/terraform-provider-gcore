# Minimal example demonstrating random_password.bcrypt_hash
# Run this to see stable hash behavior

terraform {
  required_providers {
    random = {
      source  = "hashicorp/random"
      version = "~> 3.6"
    }
  }
}

# This generates a password once and stores bcrypt_hash in state
resource "random_password" "example" {
  length  = 12
  special = false
}

# You can view the values with terraform output
output "password_plaintext" {
  description = "The generated password (sensitive)"
  value       = random_password.example.result
  sensitive   = true
}

output "password_bcrypt_hash" {
  description = "The bcrypt hash - STABLE across runs (sensitive)"
  value       = random_password.example.bcrypt_hash
  sensitive   = true
}

output "bcrypt_cost" {
  description = "The cost parameter used for bcrypt"
  value       = 10 # default cost
}

# To view these outputs:
# terraform output password_plaintext
# terraform output password_bcrypt_hash

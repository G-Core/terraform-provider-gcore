#!/usr/bin/env bash

set -euo pipefail

cd "$(dirname "$0")/.."

if [ -f "Brewfile" ] && [ "$(uname -s)" = "Darwin" ] && [ "$SKIP_BREW" != "1" ] && [ -t 0 ]; then
  brew bundle check >/dev/null 2>&1 || {
    echo -n "==> Install Homebrew dependencies? (y/N): "
    read -r response
    case "$response" in
      [yY][eE][sS]|[yY])
        brew bundle
        ;;
      *)
        ;;
    esac
    echo
  }
fi

# Mark the necessary Go modules as private to avoid Go's proxy
export GOPRIVATE="${GOPRIVATE:+$GOPRIVATE,}github.com/G-Core/gcore-go,github.com/stainless-sdks/gcore-go"

echo "==> Installing Go dependencies…"
go mod tidy -e || true

echo "==> Installing git hooks…"
if command -v lefthook &> /dev/null; then
  lefthook install
else
  echo "  lefthook not found. Install with: brew install lefthook"
  echo "  Then run: lefthook install"
fi

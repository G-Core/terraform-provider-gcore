// WORKAROUND PATCH: Flatten security_group block syntax
// Apply this after running: stainless generate
//
// This patch allows users to use EITHER:
//   1. Nested syntax (legacy): security_group = { name = "...", description = "..." }
//   2. Flat syntax (new):      name = "...", description = "..."
//
// Both syntaxes work and are mutually exclusive (validation added to ModifyPlan)

// =============================================================================
// FILE: internal/services/cloud_security_group/model.go
// =============================================================================

// CHANGE 1: Update struct tags for Name field (around line 19)
// FROM:
//   Name               types.String                                                            `tfsdk:"name" json:"name,optional"`
// TO:
   Name               types.String                                                            `tfsdk:"name" json:"-"` // Flat alternative to security_group.name

// CHANGE 2: Update the Description field tag (currently on line 23, marked as computed)
// FROM:
//   Description        types.String                                                            `tfsdk:"description" json:"description,computed"`
// TO:
   Description        types.String                                                            `tfsdk:"description" json:"-"` // Flat alternative to security_group.description

// CHANGE 3: Replace MarshalJSON method (around line 31)
// FROM:
//   func (m CloudSecurityGroupModel) MarshalJSON() (data []byte, err error) {
//   	return apijson.MarshalRoot(m)
//   }
// TO:
func (m CloudSecurityGroupModel) MarshalJSON() (data []byte, err error) {
	// WORKAROUND: Support both nested and flat syntax
	//
	// Nested syntax (API format):
	//   security_group = { name = "...", description = "..." }
	//
	// Flat syntax (user-friendly):
	//   name = "..."
	//   description = "..."
	//
	// The API always expects nested structure in the request body:
	//   { "security_group": { "name": "...", "description": "..." } }
	//
	// So we convert flat fields to nested structure before serialization.

	// Create a copy to avoid modifying the original
	model := m

	// If user provided flat fields (not nested block), construct nested structure for API
	if model.SecurityGroup == nil && !model.Name.IsNull() {
		model.SecurityGroup = &CloudSecurityGroupSecurityGroupModel{
			Name:        model.Name,
			Description: model.Description,
		}
	}

	return apijson.MarshalRoot(model)
}

// CHANGE 4: Replace MarshalJSONForUpdate method (around line 35)
// FROM:
//   func (m CloudSecurityGroupModel) MarshalJSONForUpdate(state CloudSecurityGroupModel) (data []byte, err error) {
//   	return apijson.MarshalForPatch(m, state)
//   }
// TO:
func (m CloudSecurityGroupModel) MarshalJSONForUpdate(state CloudSecurityGroupModel) (data []byte, err error) {
	// WORKAROUND: Same logic for updates
	model := m

	// Convert flat to nested if needed
	if model.SecurityGroup == nil && !model.Name.IsNull() {
		model.SecurityGroup = &CloudSecurityGroupSecurityGroupModel{
			Name:        model.Name,
			Description: model.Description,
		}
	}

	return apijson.MarshalForPatch(model, state)
}

// =============================================================================
// FILE: internal/services/cloud_security_group/resource.go
// =============================================================================

// CHANGE 5: Replace ModifyPlan method (around line 286)
// FROM:
//   func (r *CloudSecurityGroupResource) ModifyPlan(_ context.Context, _ resource.ModifyPlanRequest, _ *resource.ModifyPlanResponse) {
//
//   }
// TO:
func (r *CloudSecurityGroupResource) ModifyPlan(ctx context.Context, req resource.ModifyPlanRequest, resp *resource.ModifyPlanResponse) {
	var plan *CloudSecurityGroupModel
	resp.Diagnostics.Append(req.Plan.Get(ctx, &plan)...)
	if resp.Diagnostics.HasError() {
		return
	}

	// Skip validation if this is a destroy operation (plan will be null)
	if plan == nil {
		return
	}

	// WORKAROUND: Validate mutually exclusive syntax options
	//
	// User can choose ONE of these syntaxes:
	//   1. Nested: security_group = { name = "...", description = "..." }
	//   2. Flat:   name = "...", description = "..."
	//
	// Using both will cause confusion and is likely a mistake.

	hasNested := plan.SecurityGroup != nil && !plan.SecurityGroup.Name.IsNull()
	hasFlat := !plan.Name.IsNull()

	if hasNested && hasFlat {
		resp.Diagnostics.AddError(
			"Conflicting security group configuration",
			"Cannot use both 'security_group' block and flat 'name'/'description' attributes.\n\n"+
			"You have specified:\n"+
			"  - security_group.name = \""+plan.SecurityGroup.Name.ValueString()+"\"\n"+
			"  - name = \""+plan.Name.ValueString()+"\"\n\n"+
			"Choose ONE syntax:\n\n"+
			"Option 1 (Nested - Legacy):\n"+
			"  resource \"gcore_cloud_security_group\" \"example\" {\n"+
			"    project_id = 379987\n"+
			"    region_id  = 76\n"+
			"    security_group = {\n"+
			"      name        = \"my-sg\"\n"+
			"      description = \"Description\"\n"+
			"    }\n"+
			"  }\n\n"+
			"Option 2 (Flat - Recommended):\n"+
			"  resource \"gcore_cloud_security_group\" \"example\" {\n"+
			"    project_id  = 379987\n"+
			"    region_id   = 76\n"+
			"    name        = \"my-sg\"\n"+
			"    description = \"Description\"\n"+
			"  }",
		)
		return
	}

	if !hasNested && !hasFlat {
		resp.Diagnostics.AddError(
			"Missing required security group name",
			"Must specify security group name using ONE of these syntaxes:\n\n"+
			"Option 1 (Nested):\n"+
			"  security_group = { name = \"my-sg\" }\n\n"+
			"Option 2 (Flat):\n"+
			"  name = \"my-sg\"",
		)
		return
	}

	// project_id and region_id will use provider-level defaults automatically
}


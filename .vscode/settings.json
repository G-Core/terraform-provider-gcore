{
    "git.autoRepositoryDetection": "subFolders",
    "git.detectSubmodules": true,
    "git.worktrees.enableStatusBarSync": true,
    "git.worktrees.scope": "all",
    "files.exclude": {
        "**/.tree": false
    },
    "search.exclude": {
        "**/.tree": false
    },
    "files.watcherExclude": {
        "**/.tree/**": false
    }
}